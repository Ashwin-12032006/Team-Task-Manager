generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  role           String
  initials       String
  color          String
  phone          String?
  bio            String?
  tasksCompleted Int       @default(0)
  rating         Float     @default(0)
  velocity       String?
  onTimeRate     String?
  
  projects       ProjectMember[]
  tasks          Task[]
  pastWork       PastWork[]
}

model PastWork {
  id        String   @id @default(cuid())
  title     String
  date      String
  impact    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String
  progress    Int       @default(0)
  
  members     ProjectMember[]
  columns     BoardColumn[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model BoardColumn {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  tasks     Task[]
}

model Task {
  id        String      @id @default(cuid())
  content   String
  priority  String
  status    String      @default("To Do")
  order     Int         @default(0)
  
  columnId  String
  column    BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  
  authorId  String?
  author    User?       @relation(fields: [authorId], references: [id])
}
